# Optional overrides for config/build-tracking.json. Never commit secrets.
DEEP_CUTS_REPORTING_CURRENCY=AUD
DEEP_CUTS_EMAIL_RECIPIENT=andrewharris501@gmail.com
DEEP_CUTS_DETAILED_USAGE_EMAIL=false
DEEP_CUTS_LOG_FAILED_BUILDS=true
DEEP_CUTS_PRICING_FILE=config/ai-pricing.json

# Optional fixed USD-to-AUD conversion. Leave blank to use the configured
# public exchange-rate source when a measurable USD cost exists.
DEEP_CUTS_AUD_EXCHANGE_RATE=
DEEP_CUTS_EXCHANGE_RATE_DATE=
DEEP_CUTS_EXCHANGE_RATE_SOURCE=

# The production agent may provide a stable ID at build start.
DEEP_CUTS_BUILD_ID=
